# ---------------------------------------------------------------------------
# Frontend environment variables (Vite). Copy to .env for local overrides.
# All Vite env vars MUST be prefixed with VITE_ to be exposed to the app.
# ---------------------------------------------------------------------------

# PRODUCTION ONLY — leave UNSET if you use the vercel.json /api proxy (recommended).
# Set this to your deployed backend's base URL to call it directly (requires the
# backend CORS_ORIGINS to include your frontend origin).
# Example: https://your-backend.onrender.com
VITE_API_BASE_URL=

# DEV ONLY — override the local backend that the Vite dev server proxies /api to.
# Defaults to http://localhost:8000
VITE_PROXY_TARGET=http://localhost:8000
