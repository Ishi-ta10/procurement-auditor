# Copy this file to .env and fill in your real values. Do NOT commit real secrets.

# PostgreSQL / Supabase connection string (SQLAlchemy format)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Groq API key for the ExtractorAgent (Llama 3.3 70B)
GROQ_API_KEY=your-groq-api-key

# Gmail SMTP credentials used for escalation alerts (use an App Password, not your login)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Comma-separated list of allowed CORS origins (frontend dev server)
CORS_ORIGINS=http://localhost:5173
