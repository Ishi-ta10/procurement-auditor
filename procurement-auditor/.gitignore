# ============================================================
# Procurement Auditor — root .gitignore (backend + frontend)
# ============================================================

# ---------- Python (backend) ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
ENV/

# ---------- Secrets / environment ----------
.env
.env.*
!.env.example

# ---------- ML / runtime artifacts ----------
# Trained anomaly model (regenerated by bootstrap / GET /model/retrain)
backend/agents/*.pkl
# Uploaded invoice PDFs (runtime data)
backend/uploads/
# Local embedding model cache
**/fastembed_cache/

# ---------- Node / frontend ----------
node_modules/
dist/
dist-ssr/
.vite/
*.local

# ---------- Logs ----------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Editors / IDE ----------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
